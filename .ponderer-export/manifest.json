      "langEntries": {
        "zh_cn": {
          "create_biotech.ponder.creeper_blast_chamber_scene_1.header": "苦力怕爆破室 介绍",
          "create_biotech.ponder.creeper_blast_chamber_scene_1.text_1": "这是一个苦力怕爆破室",
          "create_biotech.ponder.creeper_blast_chamber_scene_1.text_2": "它可以高效批量地执行粉碎配方",
          "create_biotech.ponder.creeper_blast_chamber_scene_1.text_3": "或者...你想来点更劲爆的？",
          "create_biotech.ponder.creeper_blast_chamber_s_10040.header": "苦力怕爆破室 搭建",
          "create_biotech.ponder.creeper_blast_chamber_s_10040.text_1": "结构支持3种尺寸",
          "create_biotech.ponder.creeper_blast_chamber_s_10040.text_2": "结构顶面中心需为动力冲压机",
          "create_biotech.ponder.creeper_blast_chamber_s_10040.text_3": "结构底面中心需为生物打包机",
          "create_biotech.ponder.creeper_blast_chamber_s_10040.text_4": "结构的框架由防爆机壳搭成",
          "create_biotech.ponder.creeper_blast_chamber_s_10040.text_5": "除了顶面和底面的任意面中心可以被替换为防爆玻璃",
          "create_biotech.ponder.creeper_blast_chamber_s_10040.text_6": "除此之外，每个结构还必须包括一个爆破室核心",
          "create_biotech.ponder.creeper_blast_chamber_s_10040.text_7": "以及两个任意大小的防爆保险库（连接的保险库算做一个）",
          "create_biotech.ponder.creeper_blast_chamber_s_10040.text_8": "结构成型以后，顶面的棱会被自动替换为链式传动箱",
          "create_biotech.ponder.creeper_blast_chamber_s_10040.text_9": "使用扳手可以在机壳和传动箱之间切换，但是需要保证能够剩下的传动箱足以驱动所有冲压机",
          "create_biotech.ponder.creeper_blast_chamber_s_c38b1.header": "苦力怕爆破室 运作",
          "create_biotech.ponder.creeper_blast_chamber_s_c38b1.text_1": "爆炸室核心可以通过纸箱输入和输出苦力怕",
          "create_biotech.ponder.creeper_blast_chamber_s_c38b1.text_2": "最大的爆破室最多可以有9个苦力怕同时工作",
          "create_biotech.ponder.creeper_blast_chamber_s_c38b1.text_3": "通入应力...",
          "create_biotech.ponder.creeper_blast_chamber_s_c38b1.text_4": "【苦力怕开始被压缩】",
          "create_biotech.ponder.creeper_blast_chamber_s_c38b1.text_5": "【爆炸粒子】",
          "create_biotech.ponder.creeper_blast_chamber_s_c38b1.text_6": "【苦力怕恢复】",
          "create_biotech.ponder.creeper_blast_chamber_s_c38b1.text_7": "每有一只苦力怕，爆破室就会提取输入保险库中的一组物品，执行粉碎轮的粉碎配方，输出到输出保险库",
          "create_biotech.ponder.creeper_blast_chamber_s_c38b1.text_8": "右键长按保险库可以调整其为输入或输出",
          "create_biotech.ponder.creeper_blast_chamber_s_2c227.header": "苦力怕爆破室 过载",
          "create_biotech.ponder.creeper_blast_chamber_s_2c227.text_1": "苦力怕爆破室最高接受128rpm的转速",
          "create_biotech.ponder.creeper_blast_chamber_s_2c227.text_2": "超过128rpm的转速会使其进入过载状态",
          "create_biotech.ponder.creeper_blast_chamber_s_2c227.text_3": "不要长时间过载，除非你想引起一次足以炸毁你基地的大爆炸！",
          "create_biotech.ponder.creeper_blast_chamber_s_a77f7.header": "苦力怕爆破室 高压聚爆",
          "create_biotech.ponder.creeper_blast_chamber_s_a77f7.text_1": "向爆破室中输入高压苦力怕...",
          "create_biotech.ponder.creeper_blast_chamber_s_a77f7.text_2": "可以将配方调整为“高压聚爆”模式",
          "create_biotech.ponder.creeper_blast_chamber_s_a77f7.text_3": "“高压聚爆”模式有单独的配方，不再执行粉碎配方",
          "create_biotech.ponder.creeper_blast_chamber_s_a77f7.text_4": "当然，过载引起的爆炸烈度也会成倍增加"
        },
        "en_us": {
          "create_biotech.ponder.creeper_blast_chamber_scene_1.header": "Scene 1",
